{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/quotes", "dest": "/api/quotes.js" },
    { "src": "/api/crypto", "dest": "/api/crypto.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*\\.[a-zA-Z0-9]+)$", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
